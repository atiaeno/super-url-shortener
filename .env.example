APP_NAME="ShortLink"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────
# IMPORTANT: Use MySQL/PostgreSQL for production, NOT SQLite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shortlink_prod
DB_USERNAME=shortlink_user
DB_PASSWORD=secure_password_here

# ── Session ──────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache & Queue → Redis (PRODUCTION READY) ──────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=shortlink-

# ── Redis ────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@shortlink.app"
MAIL_FROM_NAME="${APP_NAME}"

# ── OAuth (Socialite) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL="${APP_URL}/auth/github/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URL="${APP_URL}/auth/facebook/callback"

# ── Google Safe Browsing ──────────────────────────────
GOOGLE_SAFE_BROWSING_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Feature Toggles (Database Settings) ─────────────
# These are managed via Admin Panel > Settings
# - features_affiliate: Enable/disable affiliate program
# - features_gdpr: Enable GDPR data retention
# - features_ads: Enable ad display on redirect pages
# - redirect_countdown: Seconds before auto-redirect (default: 5)
# - redirect_mode: auto|manual|countdown
# - redirect_captcha: Show captcha before redirect
# - captcha_enabled: Enable reCAPTCHA on forms
# - captcha_site_key: reCAPTCHA v2 site key
# - captcha_secret_key: reCAPTCHA v2 secret key
# - affiliate_min_payout: Minimum payout amount (default: 50)
# - affiliate_payout_methods: Comma-separated (PayPal,BankTransfer)
# - gdpr_data_retention_days: Click data retention (default: 365)
# - donation_enabled: Show donation button
# - donation_button_id: PayPal button ID

VITE_APP_NAME="${APP_NAME}"
